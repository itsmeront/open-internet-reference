# OIR scheduled tasks
# Install to /etc/cron.d/oir-checks

# Rebuild site every 6 hours (catches any missed webhooks)
0 */6 * * * oir bash /opt/oir/repo/deploy/deploy.sh >> /opt/oir/deploy.log 2>&1

# Run URL checker weekly (Sunday at 3am)
0 3 * * 0 www-data /opt/oir/venv/bin/python /opt/oir/repo/tools/check_urls.py --quiet >> /opt/oir/url-check.log 2>&1

# Run research debt report weekly (Monday at 6am)
0 6 * * 1 www-data /opt/oir/venv/bin/python /opt/oir/repo/tools/resolve_debt.py --summary >> /opt/oir/debt-report.log 2>&1


# Generate usage statistics daily (2am) — reads Docker nginx logs
0 2 * * * root bash -c '/opt/oir/venv/bin/python /opt/oir/repo/tools/generate_stats.py --nginx-log <(docker logs yz-webserver 2>/dev/null)' >> /opt/oir/stats.log 2>&1

# Note: deploy.sh also runs deploy/generate_site_stats.sh before each MkDocs build so
# git reset --hard origin/main does not leave the published stats page stale until cron runs.
